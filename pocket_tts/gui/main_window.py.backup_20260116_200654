        """Create collapsible parameters section."""
        # Container for checkbox and parameters
        container = QWidget()
        container_layout = QVBoxLayout(container)
        container_layout.setContentsMargins(0, 0, 0, 0)
        
        # Checkbox to toggle parameters visibility
        self.params_checkbox = QCheckBox("Show Parameters")
        self.params_checkbox.setChecked(False)  # Start unchecked (hidden)
        container_layout.addWidget(self.params_checkbox)
        
        # Parameters group (not checkable)
        self.params_group = QGroupBox("Parameters")
        layout = QVBoxLayout(self.params_group)

        # Chunking parameters
        chunking_group = self.create_collapsible_group("Chunking Settings")
        chunking_layout = QFormLayout(chunking_group)

        self.chunking_mode_combo = QComboBox()
        self.chunking_mode_combo.addItem("sentence")
        self.chunking_mode_combo.addItem("paragraph")
        chunking_layout.addRow("Mode:", self.chunking_mode_combo)

        self.min_words_spin = QSpinBox()
        self.min_words_spin.setRange(1, 20)
        self.min_words_spin.setValue(5)
        chunking_layout.addRow("Min Words:", self.min_words_spin)

        self.max_words_spin = QSpinBox()
        self.max_words_spin.setRange(20, 200)
        self.max_words_spin.setValue(50)
        chunking_layout.addRow("Max Words:", self.max_words_spin)

        # Pause parameters
        pause_group = self.create_collapsible_group("Pause Settings")
        pause_layout = QFormLayout(pause_group)



        self.sentence_pause_spin = QSpinBox()
        self.sentence_pause_spin.setMinimum(1)
        self.sentence_pause_spin.setMaximum(2000)  # Max 2 seconds in ms
        # Load from config directly (milliseconds)
        sentence_ms = self.config.pauses['base_durations']['sentence_end']
        self.sentence_pause_spin.setValue(sentence_ms)
        pause_layout.addRow("Sentence (ms):", self.sentence_pause_spin)

        self.paragraph_pause_spin = QSpinBox()
        self.paragraph_pause_spin.setMinimum(1)
        self.paragraph_pause_spin.setMaximum(5000)  # Max 5 seconds in ms
        # Load from config directly (milliseconds)
        paragraph_ms = self.config.pauses['base_durations']['paragraph_break']
        self.paragraph_pause_spin.setValue(paragraph_ms)
        pause_layout.addRow("Paragraph (ms):", self.paragraph_pause_spin)

        self.chapter_pause_spin = QSpinBox()
        self.chapter_pause_spin.setMinimum(1)
        self.chapter_pause_spin.setMaximum(10000)  # Max 10 seconds in ms
        # Load from config directly (milliseconds)
        chapter_ms = self.config.pauses['base_durations']['chapter_start']
        self.chapter_pause_spin.setValue(chapter_ms)
        pause_layout.addRow("Chapter (ms):", self.chapter_pause_spin)

        # Quality parameters
        quality_group = self.create_collapsible_group("Quality Settings")
        quality_layout = QFormLayout(quality_group)

        self.lsd_steps_spin = QSpinBox()
        self.lsd_steps_spin.setRange(1, 4)
        self.lsd_steps_spin.setValue(1)
        quality_layout.addRow("LSD Steps:", self.lsd_steps_spin)

